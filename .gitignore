# Virtual env
.venv/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/

# Data (never commit raw datasets)
data/raw/*
!data/raw/.gitkeep

# Processed data (optional: keep out to reduce repo size)
data/processed/*
!data/processed/.gitkeep

# Outputs / artifacts
outputs/

# OS / editor
.DS_Store
.vscode/
.idea/